@model UniversityManagement.Web.ViewModels.RatingStatisticsViewModel

@{
    ViewData["Title"] = "Rating Statistics";
}

<h1><span class="text-gradient">Rating Statistics</span></h1>

<div class="lumina-stat-grid mb-3">
    <article class="lumina-stat-card">
        <strong>@Model.AverageRating.ToString("0.##")</strong>
        <span>Average rating</span>
    </article>
    <article class="lumina-stat-card">
        <strong>@Model.MaxRating.ToString("0.##")</strong>
        <span>Max rating</span>
    </article>
    <article class="lumina-stat-card">
        <strong>@Model.MinRating.ToString("0.##")</strong>
        <span>Min rating</span>
    </article>
</div>

<div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Group</th>
                <th>Average rating</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var group in Model.AverageByGroup)
        {
            <tr>
                <td>@group.Key</td>
                <td>@group.Value.ToString("0.##")</td>
            </tr>
        }
        </tbody>
    </table>
</div>

<a href="@Url.Action("Index")" class="btn btn-secondary mt-3">Back</a>
