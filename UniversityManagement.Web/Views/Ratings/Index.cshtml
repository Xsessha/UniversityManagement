@model IEnumerable<UniversityManagement.Web.ViewModels.RatingViewModel>

<h2>Ratings</h2>

<div class="mb-3">
    <a asp-action="Statistics" class="btn btn-primary">Statistics</a>
    <a asp-action="TopStudents" class="btn btn-success">Top Students</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Student</th>
            <th>Group</th>
            <th>Average rating</th>
            <th>Scholarship status</th>
        </tr>
    </thead>

    <tbody>
    @foreach (var r in Model)
    {
        <tr>
            <td>@r.StudentName</td>
            <td>@r.GroupName</td>
            <td>@r.AverageRating.ToString("0.##")</td>
            <td>@r.ScholarshipStatus</td>
        </tr>
    }
    </tbody>
</table>
