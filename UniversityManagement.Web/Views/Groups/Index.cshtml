@model IEnumerable<UniversityManagement.Core.Models.Group>

@{
    ViewData["Title"] = "Groups";
    var canManage = User.IsInRole("Admin");
}

<div class="lumina-page-header">
    <div>
        <h1><span class="text-gradient">Groups</span></h1>
        <p>Academic groups with faculties, students, and courses.</p>
    </div>
    @if (canManage)
    {
        <a href="@Url.Action("Create")" class="btn btn-primary">Create Group</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Faculty</th>
                <th>Students</th>
                <th>Courses</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var group in Model)
        {
            <tr>
                <td>@group.Name</td>
                <td>@group.Faculty?.Name</td>
                <td>@group.Students.Count</td>
                <td>@group.Courses.Count</td>
                <td>
                    <a href="@Url.Action("Details", new { id = group.Id })" class="btn btn-sm btn-info">Details</a>
                    @if (canManage)
                    {
                        <a href="@Url.Action("Edit", new { id = group.Id })" class="btn btn-sm btn-warning">Edit</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
