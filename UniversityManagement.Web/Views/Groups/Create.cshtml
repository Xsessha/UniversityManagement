@model UniversityManagement.Core.Models.Group

@{
    ViewData["Title"] = "Create Group";
    var faculties = ViewBag.Faculties as List<UniversityManagement.Core.Models.Faculty> ?? new();
}

<h1>Create Group</h1>

<div class="row">
    <div class="col-lg-6">
        <form action="@Url.Action("Create", "Groups")" method="post" class="card p-4">
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input name="Name" value="@Model?.Name" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Faculty</label>
                <select name="FacultyId" class="form-control" required>
                    <option value="">-- Select faculty --</option>
                    @foreach (var faculty in faculties)
                    {
                        <option value="@faculty.Id" selected="@(Model?.FacultyId == faculty.Id)">@faculty.Name</option>
                    }
                </select>
            </div>

            <button class="btn btn-success">Create</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
