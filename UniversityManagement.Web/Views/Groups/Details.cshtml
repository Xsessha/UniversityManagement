@model UniversityManagement.Core.Models.Group

@{
    ViewData["Title"] = "Group Details";
}

<div class="lumina-page-header">
    <div>
        <h1><span class="text-gradient">@Model.Name</span></h1>
        <p>@Model.Faculty?.Name</p>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Back</a>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card p-3">
            <h3>Students</h3>
            @if (Model.Students.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var student in Model.Students.OrderBy(s => s.LastName))
                    {
                        <li class="list-group-item bg-transparent">@student.FirstName @student.LastName</li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No students in this group yet.</p>
            }
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card p-3">
            <h3>Courses</h3>
            @if (Model.Courses.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var course in Model.Courses.OrderBy(c => c.Name))
                    {
                        <li class="list-group-item bg-transparent">@course.Name - @course.Teacher?.FirstName @course.Teacher?.LastName</li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No courses assigned yet.</p>
            }
        </div>
    </div>
</div>

<div class="mt-4">
    <div class="card p-3">
        <h3>Group Schedule</h3>
        @{ var schedules = ViewBag.GroupSchedules as List<UniversityManagement.Core.Models.Schedule> ?? new(); }
        @if (schedules.Any())
        {
            <div class="table-responsive">
                <table class="table table-borderless">
                    <thead>
                        <tr>
                            <th>Day</th>
                            <th>Time</th>
                            <th>Course</th>
                            <th>Lesson</th>
                            <th>Teacher</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var schedule in schedules)
                        {
                            <tr>
                                <td>@schedule.DayOfWeek</td>
                                <td>@schedule.StartTime - @schedule.EndTime</td>
                                <td>@schedule.Lesson?.Course?.Name</td>
                                <td>@schedule.Lesson?.Topic</td>
                                <td>@schedule.Lesson?.Course?.Teacher?.FirstName @schedule.Lesson?.Course?.Teacher?.LastName</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No schedule has been created for this group yet.</p>
        }
    </div>
</div>
