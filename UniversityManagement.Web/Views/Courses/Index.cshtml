@model List<UniversityManagement.Core.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<h1 class="mb-4">📚 Courses Management</h1>

<a href="@Url.Action("Create")" class="btn btn-success mb-3">➕ Add New Course</a>

@if (Model.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Credits</th>
                    <th>Teacher</th>
                    <th>Groups</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model)
                {
                    <tr>
                        <td>@course.Name</td>
                        <td>@course.Description</td>
                        <td>@course.Credits</td>
                        <td>@(course.Teacher != null ? $"{course.Teacher.FirstName} {course.Teacher.LastName}" : "N/A")</td>
                        <td>@course.Groups.Count</td>
                        <td>
                            <a href="@Url.Action("Details", new { id = course.Id })" class="btn btn-sm btn-info">👁️ View</a>
                            <a href="@Url.Action("Edit", new { id = course.Id })" class="btn btn-sm btn-warning">✏️ Edit</a>
                            <a href="@Url.Action("Delete", new { id = course.Id })" class="btn btn-sm btn-danger">🗑️ Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info" role="alert">
        No courses found. <a href="@Url.Action("Create")">Create one now</a>
    </div>
}
    <tbody>
    @foreach (var course in Model)
    {
        <tr>
            <td>@course.Name</td>
            <td>@course.Credits</td>
            <td>@course.Teacher?.FirstName @course.Teacher?.LastName</td>
            <td>
                <a asp-action="Details" asp-route-id="@course.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@course.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@course.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>