@model IEnumerable<UniversityManagement.Core.Models.Course>

<h2>Courses</h2>

<a asp-action="Create" class="btn btn-primary">Create Course</a>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>Name</th>
            <th>Credits</th>
            <th>Teacher</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var course in Model)
    {
        <tr>
            <td>@course.Name</td>
            <td>@course.Credits</td>
            <td>@course.Teacher?.FirstName @course.Teacher?.LastName</td>
            <td>
                <a asp-action="Details" asp-route-id="@course.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@course.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@course.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>