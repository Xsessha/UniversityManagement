@model List<UniversityManagement.Core.Models.Course>

@{
    ViewData["Title"] = "Courses";
    var canManage = User.IsInRole("Admin");
}

<div class="lumina-page-header">
    <div>
        <h1><span class="text-gradient">Courses</span></h1>
        <p>Courses with assigned teachers and student groups.</p>
    </div>
    @if (canManage)
    {
        <a href="@Url.Action("Create")" class="btn btn-success">Add New Course</a>
    }
</div>

@if (Model.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Credits</th>
                    <th>Teacher</th>
                    <th>Groups / Students</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model)
                {
                    var studentsCount = course.Groups.Sum(g => g.Students.Count);
                    <tr>
                        <td>@course.Name</td>
                        <td>@course.Description</td>
                        <td>@course.Credits</td>
                        <td>@(course.Teacher != null ? $"{course.Teacher.FirstName} {course.Teacher.LastName}" : "N/A")</td>
                        <td>
                            @string.Join(", ", course.Groups.Select(g => g.Name))
                            <span class="badge bg-info ms-1">@studentsCount students</span>
                        </td>
                        <td>
                            <a href="@Url.Action("Details", new { id = course.Id })" class="btn btn-sm btn-info">View</a>
                            @if (canManage)
                            {
                                <a href="@Url.Action("Edit", new { id = course.Id })" class="btn btn-sm btn-warning">Edit</a>
                                <a href="@Url.Action("Delete", new { id = course.Id })" class="btn btn-sm btn-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">No courses found.</div>
}
