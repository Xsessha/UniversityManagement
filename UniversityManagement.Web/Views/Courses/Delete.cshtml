@model UniversityManagement.Core.Models.Course

@{
    ViewData["Title"] = "Delete Course";
}

<h1 class="mb-4">🗑️ Delete Course</h1>

<div class="alert alert-warning" role="alert">
    <strong>Are you sure you want to delete this course?</strong>
</div>

<div class="card mb-4">
    <div class="card-body">
        <p><strong>Name:</strong> @Model.Name</p>
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Credits:</strong> @Model.Credits</p>
    </div>
</div>

<form method="post" action="@Url.Action("Delete", "Courses", new { id = Model.Id })" style="display:inline;">
    <button type="submit" class="btn btn-danger">🗑️ Confirm Delete</button>
</form>
<a href="@Url.Action("Index")" class="btn btn-secondary">❌ Cancel</a>
