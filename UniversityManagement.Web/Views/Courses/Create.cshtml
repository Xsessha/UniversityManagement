@model UniversityManagement.Core.Models.Course

@{
    ViewData["Title"] = "Create Course";
    var teachers = ViewBag.Teachers as List<UniversityManagement.Core.Models.Teacher> ?? new();
    var groups = ViewBag.Groups as List<UniversityManagement.Core.Models.Group> ?? new();
    var selectedGroupIds = ViewBag.SelectedGroupIds as int[] ?? Array.Empty<int>();
}

<h1 class="mb-4">Add New Course</h1>

<div class="row">
    <div class="col-lg-8">
        <form method="post" action="@Url.Action("Create", "Courses")" class="card p-4">
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input name="Name" value="@Model?.Name" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="Description" class="form-control" rows="3" required>@Model?.Description</textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Credits</label>
                <input name="Credits" value="@(Model?.Credits ?? 3)" type="number" min="1" max="10" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Teacher</label>
                <select name="TeacherId" class="form-control" required>
                    <option value="">-- Select teacher --</option>
                    @foreach (var teacher in teachers)
                    {
                        <option value="@teacher.Id" selected="@(Model?.TeacherId == teacher.Id)">
                            @teacher.FirstName @teacher.LastName (@teacher.Department)
                        </option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Student Groups</label>
                <div class="row g-2">
                    @foreach (var group in groups)
                    {
                        <div class="col-md-6">
                            <label class="form-check card p-2">
                                <input class="form-check-input" type="checkbox" name="groupIds" value="@group.Id" checked="@selectedGroupIds.Contains(group.Id)" />
                                <span class="form-check-label">@group.Name (@group.Faculty?.Name)</span>
                            </label>
                        </div>
                    }
                </div>
            </div>

            <button type="submit" class="btn btn-success">Create</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
