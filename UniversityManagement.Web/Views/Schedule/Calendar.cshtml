@model IEnumerable<UniversityManagement.Core.Models.Schedule>

@{
    ViewData["Title"] = "Calendar";
}

<div class="lumina-page-header">
    <div>
        <h1><span class="text-gradient">Calendar</span></h1>
        <p>Visual list of scheduled lessons.</p>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Back</a>
</div>

<div class="lumina-list">
    @if (Model.Any())
    {
        @foreach (var item in Model.OrderBy(x => x.Lesson?.Date))
        {
            <div class="lumina-list-item">
                <strong>@item.DayOfWeek @item.StartTime - @item.EndTime</strong>
                <small>@item.Group?.Name - @item.Lesson?.Course?.Name - @item.Lesson?.Type</small>
                <div>@item.Lesson?.Course?.Teacher?.FirstName @item.Lesson?.Course?.Teacher?.LastName</div>
            </div>
        }
    }
    else
    {
        <div class="lumina-list-item">
            <strong>No schedule entries found.</strong>
            <small>There are no lessons scheduled for the selected period.</small>
        </div>
    }
</div>
