@model UniversityManagement.Core.Models.Schedule
@using UniversityManagement.Core.Enums

@{
    ViewData["Title"] = Model?.Id > 0 ? "Edit Lesson" : "Create Lesson";
    var groups = ViewBag.Groups as List<UniversityManagement.Core.Models.Group> ?? new();
    var lessons = ViewBag.Lessons as List<UniversityManagement.Core.Models.Lesson> ?? new();
    var courses = ViewBag.Courses as List<UniversityManagement.Core.Models.Course> ?? new();
    var lessonTypes = ViewBag.LessonTypes as LessonType[] ?? Enum.GetValues<LessonType>();
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-lg-7">
        @if (Model?.Id > 0)
        {
            <form action="@Url.Action("Edit", "Schedule", new { id = Model.Id })" method="post" class="card p-4">
                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="mb-3">
                    <label class="form-label">Group</label>
                    <select name="GroupId" class="form-control" required>
                        @foreach (var group in groups)
                        {
                            <option value="@group.Id" selected="@(Model.GroupId == group.Id)">
                                @group.Name (@group.Faculty?.Name)
                            </option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Lesson</label>
                    <select name="LessonId" class="form-control" required>
                        @foreach (var lesson in lessons)
                        {
                            <option value="@lesson.Id" selected="@(Model.LessonId == lesson.Id)">
                                @lesson.Date.ToString("dd.MM.yyyy HH:mm") - @lesson.Course?.Name - @lesson.Type
                            </option>
                        }
                    </select>
                </div>

                <button type="submit" class="btn btn-success">Save</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
            </form>
        }
        else
        {
            <form action="@Url.Action("CreateLesson", "Schedule")" method="post" class="card p-4">
                <div class="mb-3">
                    <label class="form-label">Group</label>
                    <select name="groupId" class="form-control" required>
                        <option value="">-- Select group --</option>
                        @foreach (var group in groups)
                        {
                            <option value="@group.Id">@group.Name (@group.Faculty?.Name)</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Course</label>
                    <select name="courseId" class="form-control" required>
                        <option value="">-- Select course --</option>
                        @foreach (var course in courses)
                        {
                            <option value="@course.Id">@course.Name - @course.Teacher?.FirstName @course.Teacher?.LastName</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Topic</label>
                    <input name="topic" class="form-control" placeholder="Lesson topic" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Lesson Type</label>
                    <select name="lessonType" class="form-control">
                        @foreach (var type in lessonTypes)
                        {
                            <option value="@type">@type</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Date and Time</label>
                    <input name="date" type="datetime-local" class="form-control" required />
                </div>

                <button type="submit" class="btn btn-success">Save</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
            </form>
        }
    </div>
</div>
