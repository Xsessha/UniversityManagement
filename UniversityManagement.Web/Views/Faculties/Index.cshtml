@model IEnumerable<UniversityManagement.Core.Models.Faculty>

@{
    ViewData["Title"] = "Faculties";
    var canManage = User.IsInRole("Admin");
}

<div class="lumina-page-header">
    <div>
        <h1><span class="text-gradient">Faculties</span></h1>
        <p>University faculties and their academic groups.</p>
    </div>
    @if (canManage)
    {
        <a href="@Url.Action("Create")" class="btn btn-primary">Create Faculty</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Dean</th>
                <th>Groups</th>
                <th>Students</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var faculty in Model)
        {
            <tr>
                <td>@faculty.Name</td>
                <td>@faculty.Dean</td>
                <td>@faculty.Groups.Count</td>
                <td>@faculty.Groups.Sum(g => g.Students.Count)</td>
                <td>
                    <a href="@Url.Action("TreeView", new { id = faculty.Id })" class="btn btn-sm btn-info">Tree</a>
                    @if (canManage)
                    {
                        <a href="@Url.Action("Edit", new { id = faculty.Id })" class="btn btn-sm btn-warning">Edit</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
