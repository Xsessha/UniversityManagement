@model IEnumerable<UniversityManagement.Core.Models.Attendance>

@{
    ViewData["Title"] = "Attendance";
    var canMark = User.IsInRole("Admin") || User.IsInRole("Teacher");
}

<div class="lumina-page-header">
    <div>
        <h1><span class="text-gradient">Attendance</span></h1>
        <p>Attendance journal by student, lesson, and course.</p>
    </div>
    @if (canMark)
    {
        <a href="@Url.Action("MarkAttendance")" class="btn btn-primary">Mark Attendance</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Student</th>
                <th>Group</th>
                <th>Course / Lesson</th>
                <th>Status</th>
                <th>Date</th>
                @if (canMark)
                {
                    <th></th>
                }
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Student?.FirstName @item.Student?.LastName</td>
                <td>@item.Student?.Group?.Name</td>
                <td>@item.Lesson?.Course?.Name - @item.Lesson?.Topic</td>
                <td><span class="badge bg-info">@item.Status</span></td>
                <td>@item.Date.ToShortDateString()</td>
                @if (canMark)
                {
                    <td><a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-warning">Edit</a></td>
                }
            </tr>
        }
        </tbody>
    </table>
</div>
