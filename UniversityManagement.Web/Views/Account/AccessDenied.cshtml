@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger text-center" role="alert">
                <h2>🚫 Access Denied</h2>
                <p class="mt-3">You don't have permission to access this resource.</p>
                <a href="@Url.Action("Index", "Home")" class="btn btn-primary mt-3">🔙 Back to Home</a>
                <a href="@Url.Action("Logout", "Account")" class="btn btn-outline-secondary mt-3">Logout</a>
            </div>
        </div>
    </div>
</div>