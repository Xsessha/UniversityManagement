<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Lumina Campus") - University Management System</title>
    <script>
        try {
            var theme = localStorage.getItem("lumina-theme");
            document.documentElement.classList.toggle("dark", theme ? theme === "dark" : true);
        } catch (e) {
            document.documentElement.classList.add("dark");
        }
    </script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Url.Content("~/css/site.css")" />
    <link rel="stylesheet" href="@Url.Content("~/css/dashboard.css")" />
    <link rel="stylesheet" href="@Url.Content("~/css/lumina.css")" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <div class="lumina-shell">
            @await Html.PartialAsync("_Sidebar")
            <div class="lumina-workspace">
                @await Html.PartialAsync("_Navbar")
                <main class="lumina-main">
                    @RenderBody()
                </main>
                @await Html.PartialAsync("_Footer")
            </div>
        </div>
    }
    else
    {
        <div class="lumina-public">
            @await Html.PartialAsync("_Navbar")
            <main class="lumina-main lumina-main-public">
                @RenderBody()
            </main>
            @await Html.PartialAsync("_Footer")
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/lucide@0.575.0"></script>
    <script src="@Url.Content("~/js/lumina.js")"></script>
    <script src="@Url.Content("~/lib/signalr/signalr.js")"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
