@model IEnumerable<UniversityManagement.Core.Models.Faculty>

@{
    ViewData["Title"] = "Faculty Report";
}

<div class="lumina-page-header">
    <div>
        <h1><span class="text-gradient">Faculty Report</span></h1>
        <p>Faculty structure by groups, students, and courses.</p>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Back</a>
</div>

<div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Faculty</th>
                <th>Dean</th>
                <th>Groups</th>
                <th>Students</th>
                <th>Courses</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var faculty in Model)
        {
            <tr>
                <td>@faculty.Name</td>
                <td>@faculty.Dean</td>
                <td>@faculty.Groups.Count</td>
                <td>@faculty.Groups.Sum(g => g.Students.Count)</td>
                <td>@faculty.Groups.SelectMany(g => g.Courses).Select(c => c.Id).Distinct().Count()</td>
            </tr>
        }
        </tbody>
    </table>
</div>
