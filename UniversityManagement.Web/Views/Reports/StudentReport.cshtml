@model IEnumerable<UniversityManagement.Core.Models.Student>

@{
    ViewData["Title"] = "Student Report";
}

<div class="lumina-page-header">
    <div>
        <h1><span class="text-gradient">Student Report</span></h1>
        <p>Academic status, groups, faculties, and ratings.</p>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Back</a>
</div>

<div class="table-responsive">
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Faculty</th>
                <th>Group</th>
                <th>Rating</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.FirstName @student.LastName</td>
                <td>@student.Group?.Faculty?.Name</td>
                <td>@student.Group?.Name</td>
                <td>@student.Rating</td>
                <td><span class="badge bg-info">@student.Status</span></td>
            </tr>
        }
        </tbody>
    </table>
</div>
