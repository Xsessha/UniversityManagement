@model IEnumerable<UniversityManagement.Core.Models.Report>

@{
    ViewData["Title"] = "Reports";
}

<div class="lumina-page-header">
    <div>
        <h1><span class="text-gradient">Reports Dashboard</span></h1>
        <p>Generated academic and faculty reports.</p>
    </div>
    <div class="lumina-actions">
        <a href="@Url.Action("StudentReport")" class="btn btn-primary">Student Report</a>
        <a href="@Url.Action("FacultyReport")" class="btn btn-secondary">Faculty Report</a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Title</th>
                <th>Generated by</th>
                <th>Date generated</th>
                <th>Summary</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var report in Model)
        {
            <tr>
                <td>@report.Title</td>
                <td>@report.GeneratedBy</td>
                <td>@report.CreatedAt.ToShortDateString()</td>
                <td>@report.Description</td>
            </tr>
        }
        </tbody>
    </table>
</div>
