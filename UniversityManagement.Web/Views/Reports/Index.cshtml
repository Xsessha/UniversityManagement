@model IEnumerable<UniversityManagement.Core.Models.Report>

@{
    ViewData["Title"] = "Reports";
}

<h2>Reports Dashboard</h2>

<div class="mb-3">
    <a asp-action="StudentReport" class="btn btn-primary">Student Report</a>
    <a asp-action="FacultyReport" class="btn btn-secondary">Faculty Report</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Generated by</th>
            <th>Date generated</th>
            <th>Summary</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var report in Model)
    {
        <tr>
            <td>@report.Title</td>
            <td>Teacher #@report.GeneratedBy</td>
            <td>@report.CreatedAt.ToShortDateString()</td>
            <td>@report.Description</td>
        </tr>
    }
    </tbody>
</table>
