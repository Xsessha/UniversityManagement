@model List<UniversityManagement.Core.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<h1 class="mb-4">👨‍🎓 Students Management</h1>

<a href="@Url.Action("Create")" class="btn btn-success mb-3">➕ Add New Student</a>

@if (Model.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Group</th>
                    <th>Status</th>
                    <th>Rating</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td>@student.FirstName @student.LastName</td>
                        <td>@student.Email</td>
                        <td>@student.GroupId</td>
                        <td>
                            <span class="badge bg-info">@student.Status</span>
                        </td>
                        <td>⭐ @student.Rating</td>
                        <td>
                            <a href="@Url.Action("Details", new { id = student.Id })" class="btn btn-sm btn-info">👁️ View</a>
                            <a href="@Url.Action("Edit", new { id = student.Id })" class="btn btn-sm btn-warning">✏️ Edit</a>
                            <a href="@Url.Action("Delete", new { id = student.Id })" class="btn btn-sm btn-danger">🗑️ Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info" role="alert">
        No students found. <a href="@Url.Action("Create")">Create one now</a>
    </div>
}