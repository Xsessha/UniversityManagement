@model IEnumerable<UniversityManagement.Core.Models.Notification>

@{
    ViewData["Title"] = "Notifications";
}

<div class="lumina-page-header">
    <div>
        <h1><span class="text-gradient">Notifications</span></h1>
        <p>System and academic messages for users.</p>
    </div>
</div>

<div class="lumina-list">
    @foreach (var notification in Model)
    {
        <div class="lumina-list-item">
            <div class="d-flex justify-content-between gap-3">
                <strong>@notification.Title</strong>
                <small>@notification.CreatedAt.ToString("g")</small>
            </div>
            <small>@notification.Message</small>
            @if (notification.Student != null)
            {
                <div><span class="badge bg-info mt-2">@notification.Student.FirstName @notification.Student.LastName (@notification.Student.Group?.Name)</span></div>
            }
        </div>
    }
</div>
