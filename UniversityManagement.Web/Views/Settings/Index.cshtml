@{
    ViewData["Title"] = "Settings";
}

<div class="lumina-page-header">
    <div>
        <h1><span class="text-gradient">System Settings</span></h1>
        <p>Administrative configuration overview.</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card p-3 h-100">
            <h3>Security</h3>
            <p>ASP.NET Core Identity, cookie authentication, role-based authorization, and protected routes are enabled.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 h-100">
            <h3>Notifications</h3>
            <p>System notifications are seeded and available through the Notifications module.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 h-100">
            <h3>University Data</h3>
            <p>Faculties, groups, courses, lessons, ratings, reports, and attendance records are initialized on startup.</p>
        </div>
    </div>
</div>
